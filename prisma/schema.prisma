generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Asset {
  id           String @id @default(cuid())
  symbol       String // e.g., 'BTC', 'VESAF', 'VNINDEX', 'SJC'
  name         String
  assetClass   String // 'CRYPTO', 'MUTUAL_FUND', 'STOCK', 'GOLD', 'TERM_DEPOSIT', 'REAL_ESTATE'
  targetWeight Float  @default(0)

  prices       DailyPrice[]
  transactions Transaction[]
  termDeposits TermDeposit[]
}

model DailyPrice {
  id         String   @id @default(cuid())
  assetId    String
  date       DateTime
  closePrice Float // Strictly VND
  source     String // 'coingecko', 'fmarket', 'vndirect', 'vnappmob'

  asset Asset @relation(fields: [assetId], references: [id])

  // Prevents n8n from creating duplicate rows if run twice in one day
  @@unique([assetId, date])
}

model Transaction {
  id           String   @id @default(cuid())
  assetId      String
  date         DateTime // Required for the XIRR calculation
  type         String // 'BUY', 'SELL', 'DIVIDEND', 'INTEREST'
  quantity     Float
  pricePerUnit Float // Strictly VND
  grossAmount  Float // Negative for cash flowing OUT (Buy), Positive for cash flowing IN (Sell)

  asset Asset @relation(fields: [assetId], references: [id])
}

enum CashTransactionType {
  DEPOSIT
  WITHDRAWAL
  DIVIDEND
  INTEREST
  BUY_ASSET
  SELL_ASSET
}

model CashTransaction {
  id          String              @id @default(cuid())
  date        DateTime
  amount      Float
  currency    String              @default("VND")
  type        CashTransactionType
  description String?
  referenceId String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

// Specialized table for deterministically calculating offline bank savings
model TermDeposit {
  id           String   @id @default(cuid())
  assetId      String
  bankName     String
  principal    Float // VND
  startDate    DateTime
  maturityDate DateTime
  interestRate Float // Annual percentage

  asset Asset @relation(fields: [assetId], references: [id])
}

model PortfolioSnapshot {
  id            String   @id @default(cuid())
  date          DateTime @unique // Normalized to midnight
  totalValue    Float
  investedValue Float    // Current Market Value of assets
  cashBalance   Float
  costBasis     Float    @default(0) // Total Net Capital Deployed
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
