generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Asset {
  id           String        @id @default(cuid())
  symbol       String
  name         String
  assetClass   String
  targetWeight Float?        @default(0)
  currency     String        @default("VND")
  prices       DailyPrice[]
  termDeposits TermDeposit[]
  transactions Transaction[]
}

model DailyPrice {
  id         String   @id @default(cuid())
  assetId    String
  date       DateTime
  closePrice Float
  source     String
  asset      Asset    @relation(fields: [assetId], references: [id])

  @@unique([assetId, date])
}

model Transaction {
  id           String   @id @default(cuid())
  assetId      String
  date         DateTime
  type         String
  quantity     Float
  pricePerUnit Float
  grossAmount  Float
  asset        Asset    @relation(fields: [assetId], references: [id])
}

model CashTransaction {
  id          String              @id @default(cuid())
  date        DateTime
  amount      Float
  currency    String              @default("VND")
  type        CashTransactionType
  description String?
  referenceId String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model TermDeposit {
  id           String   @id @default(cuid())
  assetId      String
  bankName     String
  principal    Float
  startDate    DateTime
  maturityDate DateTime
  interestRate Float
  asset        Asset    @relation(fields: [assetId], references: [id])
}

model PortfolioSnapshot {
  id            String   @id @default(cuid())
  date          DateTime @unique
  totalValue    Float
  investedValue Float
  cashBalance   Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  costBasis     Float    @default(0)
}

model annotation_tag_entity {
  id                        String                      @id(map: "PK_69dfa041592c30bbc0d4b84aa00") @db.VarChar(16)
  name                      String                      @unique(map: "IDX_ae51b54c4bb430cf92f48b623f") @db.VarChar(24)
  createdAt                 DateTime                    @default(dbgenerated("CURRENT_TIMESTAMP(3)")) @db.Timestamptz(3)
  updatedAt                 DateTime                    @default(dbgenerated("CURRENT_TIMESTAMP(3)")) @db.Timestamptz(3)
  execution_annotation_tags execution_annotation_tags[]
}

model auth_identity {
  userId       String?  @db.Uuid
  providerId   String   @db.VarChar(255)
  providerType String   @db.VarChar(32)
  createdAt    DateTime @default(dbgenerated("CURRENT_TIMESTAMP(3)")) @db.Timestamptz(3)
  updatedAt    DateTime @default(dbgenerated("CURRENT_TIMESTAMP(3)")) @db.Timestamptz(3)
  user         user?    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([providerId, providerType])
}

model auth_provider_sync_history {
  id           Int      @id @default(autoincrement())
  providerType String   @db.VarChar(32)
  runMode      String
  status       String
  startedAt    DateTime @default(now()) @db.Timestamptz(3)
  endedAt      DateTime @default(now()) @db.Timestamptz(3)
  scanned      Int
  created      Int
  updated      Int
  disabled     Int
  error        String?
}

